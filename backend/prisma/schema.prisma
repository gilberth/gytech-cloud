generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                 String              @id @default(uuid())
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  username           String              @unique
  email              String              @unique
  password           String?
  isAdmin            Boolean             @default(false)
  totpEnabled        Boolean             @default(false)
  totpVerified       Boolean             @default(false)
  totpSecret         String?
  ldapDN             String?             @unique
  loginTokens        LoginToken[]
  oAuthUsers         OAuthUser[]
  refreshTokens      RefreshToken[]
  resetPasswordToken ResetPasswordToken?
  reverseShares      ReverseShare[]
  shares             Share[]
}

model RefreshToken {
  id           String   @id @default(uuid())
  token        String   @unique @default(uuid())
  createdAt    DateTime @default(now())
  expiresAt    DateTime
  userId       String
  oauthIDToken String?
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model LoginToken {
  token     String   @id @default(uuid())
  createdAt DateTime @default(now())
  expiresAt DateTime
  userId    String
  used      Boolean  @default(false)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ResetPasswordToken {
  token     String   @id @default(uuid())
  createdAt DateTime @default(now())
  expiresAt DateTime
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model OAuthUser {
  id               String @id @default(uuid())
  provider         String
  providerUserId   String
  providerUsername String
  userId           String
  user             User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Share {
  id              String           @id @default(uuid())
  createdAt       DateTime         @default(now())
  name            String?
  uploadLocked    Boolean          @default(false)
  isZipReady      Boolean          @default(false)
  views           Int              @default(0)
  expiration      DateTime
  description     String?
  removedReason   String?
  creatorId       String?
  reverseShareId  String?
  storageProvider String           @default("LOCAL")
  files           File[]
  reverseShare    ReverseShare?    @relation(fields: [reverseShareId], references: [id], onDelete: Cascade)
  creator         User?            @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  recipients      ShareRecipient[]
  security        ShareSecurity?
}

model ReverseShare {
  id                    String   @id @default(uuid())
  createdAt             DateTime @default(now())
  token                 String   @unique @default(uuid())
  shareExpiration       DateTime
  maxShareSize          String
  sendEmailNotification Boolean
  remainingUses         Int
  simplified            Boolean  @default(false)
  publicAccess          Boolean  @default(true)
  creatorId             String
  creator               User     @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  shares                Share[]
}

model ShareRecipient {
  id      String @id @default(uuid())
  email   String
  shareId String
  share   Share  @relation(fields: [shareId], references: [id], onDelete: Cascade)
}

model File {
  id               String                @id @default(uuid())
  createdAt        DateTime              @default(now())
  name             String
  size             String
  shareId          String
  share            Share                 @relation(fields: [shareId], references: [id], onDelete: Cascade)
  storageLocations FileStorageLocation[]
}

model FileStorageLocation {
  id            String    @id @default(uuid())
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  fileId        String
  provider      String
  storedPath    String
  state         String
  checksum      String?
  sizeBytes     BigInt?
  lastAttemptAt DateTime?
  attempts      Int       @default(0)
  lastSyncAt    DateTime?
  errorCode     String?
  errorMessage  String?
  file          File      @relation(fields: [fileId], references: [id], onDelete: Cascade)

  @@unique([fileId, provider], name: "fileId_provider")
  @@index([state])
  @@index([provider, state])
  @@index([fileId, provider])
}

model ShareSecurity {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  password  String?
  maxViews  Int?
  shareId   String?  @unique
  share     Share?   @relation(fields: [shareId], references: [id], onDelete: Cascade)
}

model Config {
  updatedAt    DateTime @updatedAt
  name         String
  category     String
  type         String
  defaultValue String   @default("")
  value        String?
  obscured     Boolean  @default(false)
  secret       Boolean  @default(true)
  locked       Boolean  @default(false)
  order        Int

  @@id([name, category])
}
